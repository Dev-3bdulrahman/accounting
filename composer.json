{
    "name": "dev-3bdulrahman/accounting",
    "description": "A full-featured Accounting module for Laravel ERP — journal entries, accounts, taxes, expenses & bank accounts.",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulrahman",
            "homepage": "https://3bdulrahman.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Dev3bdulrahman\\Accounting\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dev3bdulrahman\\Accounting\\Providers\\AccountingServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
